@page "/login"
@layout AuthLayout
@using BonGoo.Web.Setup.Services

<h5 class="mb-3 text-center">Anmelden</h5>

<EditForm Model="@loginRequest" OnValidSubmit="HandleLogin">
    <DataAnnotationsValidator />
    
    <div class="mb-3">
        <label class="form-label">E-Mail</label>
        <InputText @bind-Value="loginRequest.Email" class="form-control form-control-sm" type="email" />
        <ValidationMessage For="() => loginRequest.Email" class="text-danger small" />
    </div>
    
    <div class="mb-3">
        <label class="form-label">Passwort</label>
        <InputText @bind-Value="loginRequest.Password" class="form-control form-control-sm" type="password" />
        <ValidationMessage For="() => loginRequest.Password" class="text-danger small" />
    </div>
    
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger py-2 small">@errorMessage</div>
    }
    
    <button type="submit" class="btn btn-secondary w-100 btn-sm" disabled="@isLoading">
        @if (isLoading)
        {
            <span class="spinner-border spinner-border-sm me-1"></span>
        }
        Anmelden
    </button>
</EditForm>

<div class="mt-3 text-center">
    <small class="text-muted">
        Noch kein Konto? <a href="/register" class="text-decoration-none">Registrieren</a>
    </small>
</div>

@code {
    private LoginRequest loginRequest = new();
    private bool isLoading;
    private string errorMessage = string.Empty;

    [Inject] private IAuthService AuthService { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = string.Empty;

        try
        {
            var result = await AuthService.LoginAsync(loginRequest);
            if (result is not null)
            {
                Navigation.NavigateTo("/");
            }
            else
            {
                errorMessage = "Ungültige Anmeldedaten";
            }
        }
        catch (Exception)
        {
            errorMessage = "Ein Fehler ist aufgetreten";
        }
        finally
        {
            isLoading = false;
        }
    }
}
